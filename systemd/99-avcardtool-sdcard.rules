# udev rules for automatic aviation SD card processing
#
# When a FAT32-formatted SD card is inserted, two systemd services fire:
#   avcardtool-processor@<dev>  — flight log analysis and upload
#   avcardtool-navdata@<dev>    — navigation database auto-update
#
# Both run as one-shot services and log to the systemd journal.
#
# Installation:
#   sudo cp 99-avcardtool-sdcard.rules /etc/udev/rules.d/
#   sudo cp avcardtool-processor@.service /etc/systemd/system/
#   sudo cp avcardtool-navdata@.service   /etc/systemd/system/
#   sudo udevadm control --reload-rules
#   sudo systemctl daemon-reload
#
# Monitoring:
#   journalctl -u "avcardtool-*@*" -f

# sdX partitions (USB card readers, most external adapters)
ACTION=="add", \
  KERNEL=="sd[a-z][0-9]", \
  SUBSYSTEM=="block", \
  ENV{ID_FS_TYPE}=="vfat", \
  TAG+="systemd", \
  ENV{SYSTEMD_WANTS}="avcardtool-processor@%k.service avcardtool-navdata@%k.service"

# mmcblkXpY partitions (built-in SD card readers)
ACTION=="add", \
  KERNEL=="mmcblk[0-9]p[0-9]", \
  SUBSYSTEM=="block", \
  ENV{ID_FS_TYPE}=="vfat", \
  TAG+="systemd", \
  ENV{SYSTEMD_WANTS}="avcardtool-processor@%k.service avcardtool-navdata@%k.service"
